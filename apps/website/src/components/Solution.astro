---
const features = [
  {
    title: "Drag & Drop Pipeline Builder",
    description: "Visually design your promotion flow. Define environments, gates, and approvals without writing YAML.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-primary" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="12" r="1"/><circle cx="9" cy="5" r="1"/><circle cx="9" cy="19" r="1"/></svg>`,
  },
  {
    title: "Promotion Branches",
    description: "Each environment gets its own isolated branch. Conflicts stay contained instead of polluting your feature work.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-primary" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="6" x2="6" y1="3" y2="15"/><circle cx="18" cy="6" r="3"/><circle cx="6" cy="18" r="3"/><path d="M18 9a9 9 0 0 1-9 9"/></svg>`,
  },
  {
    title: "Live Dashboard",
    description: "See every feature's journey from dev to prod in real time. Know exactly what's deployed, what's waiting, and what's blocked.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-primary" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="3" rx="2"/><path d="M3 9h18"/><path d="M9 21V9"/></svg>`,
  },
];
---

<section id="solution" class="border-t border-border py-24 md:py-32">
  <div class="mx-auto max-w-6xl px-6">
    <div class="mx-auto max-w-2xl text-center">
      <h2 class="text-3xl font-bold tracking-tight sm:text-4xl">
        Visual promotion pipelines that keep your branches clean
      </h2>
      <p class="mt-4 text-lg text-text-muted">
        Convoye gives you a structured, visual way to promote code through every environment.
      </p>
    </div>

    <div class="mt-16 grid gap-6 md:grid-cols-3">
      {features.map((f) => (
        <div class="group rounded-2xl border border-border bg-surface/50 p-6 transition hover:border-primary/30 hover:bg-surface">
          <div class="mb-4 flex h-11 w-11 items-center justify-center rounded-xl bg-primary/10">
            <Fragment set:html={f.icon} />
          </div>
          <h3 class="text-lg font-semibold">{f.title}</h3>
          <p class="mt-2 text-sm leading-relaxed text-text-muted">{f.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
